; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="TowerMercs"
config/tags=PackedStringArray("current", "personal_project")
run/main_scene="res://Scenes/WorldMap/WorldMap.tscn"
config/features=PackedStringArray("4.5", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

PlayerData="*res://Scripts/Save/player_data.gd"
ItemDatabase="*res://Scripts/Data/item_database.gd"
SaveManager="*res://Scripts/Save/save_manager.gd"
MusicManager="*res://Scripts/Audio/music_manager.gd"

[editor_plugins]

enabled=PackedStringArray()

[file_customization]

folder_colors={
"res://Audio/": "blue",
"res://Data/": "yellow",
"res://Images/": "red",
"res://Models/": "pink",
"res://Resources/": "orange",
"res://Scenes/": "green",
"res://Scripts/": "purple"
}

